rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── dates ────────────────────────────────────────────────────────────────
    match /dates/{dateId} {
      // Dono: lê e escreve tudo
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.userId;

      // Criação: só o próprio usuário pode criar com seu userId
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;

      // Pessoa vinculada: leitura se withPartnerId == seu UID
      allow read: if request.auth != null
                  && resource.data.withPartnerId == request.auth.uid;

      // Pessoa vinculada: só pode gravar partnerNote, partnerDecision, partnerDecisionReason,
      // partnerRating, partnerReview, partnerQuickAnswers e updatedAt
      allow update: if request.auth != null
                    && resource.data.withPartnerId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                                        .hasOnly(['partnerNote', 'partnerDecision', 'partnerDecisionReason',
                                                  'partnerRating', 'partnerReview', 'partnerQuickAnswers',
                                                  'status', 'updatedAt']);
    }

    // ── partnerships ─────────────────────────────────────────────────────────
    match /partnerships/{partnershipId} {
      // Criação: só quem enviou o convite (requester)
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.requesterId;

      // Leitura: quem enviou OU quem recebeu (por UID ou por e-mail — cobre pending)
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.requesterId
                      || request.auth.uid == resource.data.recipientId
                      || resource.data.requesterEmail == request.auth.token.email
                      || resource.data.recipientEmail == request.auth.token.email);

      // Atualização: quem enviou OU quem recebeu (aceitar/recusar, preencher recipientId)
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.requesterId
                        || request.auth.uid == resource.data.recipientId
                        || resource.data.requesterEmail == request.auth.token.email
                        || resource.data.recipientEmail == request.auth.token.email);

      // Deleção: quem enviou OU quem recebeu (por UID ou e-mail)
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.requesterId
                        || request.auth.uid == resource.data.recipientId
                        || resource.data.requesterEmail == request.auth.token.email
                        || resource.data.recipientEmail == request.auth.token.email);
    }

    // ── ideas ─────────────────────────────────────────────────────────────────
    match /ideas/{ideaId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
    }

    // ── notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Só o destinatário pode ler suas notificações
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.toUserId;

      // Criação: feita pelo parceiro (withPartnerId) ao responder um date
      // Qualquer usuário autenticado pode criar (a lógica de autorização está no cliente)
      allow create: if request.auth != null;

      // Atualização (marcar como lida): só o destinatário
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.toUserId
                    && request.resource.data.diff(resource.data).affectedKeys()
                                        .hasOnly(['read']);
    }

    // ── userPreferences ───────────────────────────────────────────────────────
    match /userPreferences/{userId} {
      // Dono: lê e escreve suas próprias preferências
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // Parceiros com parceria aceita podem ler as preferências do dono
      // (verificação feita no cliente via getPartnership; regra permissiva para leitura
      //  pois o documento não tem referência ao parceiro, apenas ao dono)
      allow read: if request.auth != null;
    }

    // ── brasaSessions ─────────────────────────────────────────────────────────
    match /brasaSessions/{sessionId} {
      // Criação: qualquer usuário autenticado (é o p1 que cria)
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.p1Uid;

      // Leitura: p1 ou p2 da sessão
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.p1Uid
                      || request.auth.uid == resource.data.p2Uid);

      // Atualização: p1 ou p2 da sessão
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.p1Uid
                        || request.auth.uid == resource.data.p2Uid);

      // Entrada (join): qualquer autenticado pode ler para encontrar pelo código
      allow read: if request.auth != null;
    }
  }
}
