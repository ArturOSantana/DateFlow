{
  "name": "dateflow-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions para o DateFlow",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.5.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.29"
  },
  "private": true
}
