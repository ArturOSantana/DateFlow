VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# (Opcional) VAPID Key para entrega extra via FCM quando o app está fechado
# Obtenha em: Firebase Console → Configurações do Projeto → Cloud Messaging → Certificados push da Web
# Sem ela, as notificações chegam via Firestore onSnapshot no service worker.
# VITE_FIREBASE_VAPID_KEY=your_vapid_key
